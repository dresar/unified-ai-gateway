# Minimal env production.
# Vercel sudah memberi NODE_ENV=production otomatis.

DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Serverless aman: pool kecil, logging ringan, tanpa shared cache eksternal.
DB_MAX_POOL=1
BREAKER_TIMEOUT_MS=15000

# Pastikan cold start tidak menjalankan migrasi.
ENABLE_RUNTIME_MIGRATIONS=false

# Optional:
# VITE_API_BASE_URL=https://your-domain.com
# CORS_ORIGINS=https://your-domain.com,https://your-project.vercel.app
# Jika dikosongkan, backend akan auto-detect domain Vercel.
