# Mode aplikasi. Isi dua-duanya supaya frontend/backend sama-sama eksplisit production.
MODE=production
NODE_ENV=production

# URL koneksi PostgreSQL production.
# Contoh cocok untuk Neon / Supabase Postgres / managed Postgres lain.
DATABASE_URL=postgresql://neondb_owner:npg_CRWPpk7YF6vA@ep-frosty-scene-a1cugl6e-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_SECRET=ef13cc7f8cac0f23bbc714c1239cf5d15b11f790
REDIS_URL="rediss://default:gQAAAAAAASh8AAIncDI2MGRlMjgxM2U0ODc0M2Y5YjBhZGYxZjRmZDVkZTNjZHAyNzU5MDA@evolving-cheetah-75900.upstash.io:6379"
# Domain frontend yang diizinkan mengakses API.
# Untuk Vercel bisa isi domain deploy utama dan custom domain jika ada.
CORS_ORIGINS=https://unified-inky-eight.vercel.app,https://your-domain.com

# Pool DB kecil lebih aman untuk serverless.
DB_MAX_POOL=1

# Wajibkan Redis aktif di production.
REQUIRE_REDIS_IN_PRODUCTION=true

# Anda minta semua fitur aktif di production, jadi seluruh flag di bawah saya nyalakan.
# Catatan: ini fungsional, tapi tidak semuanya aman untuk production publik.
ENABLE_RUNTIME_MIGRATIONS=true
ENABLE_DEV_LOGIN=true
ENABLE_INTERNAL_TEST_ROUTES=true
ENABLE_SELF_REGISTRATION=true
ALLOW_CREDENTIAL_EXPORT=true
EXPOSE_METRICS=true
EXPOSE_OPENAPI=true

# Konfigurasi limit dan proteksi.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT=1000
BREAKER_TIMEOUT_MS=500
BREAKER_HALF_OPEN_AFTER_MS=500
API_KEY_GRACE_MS=60000
HMAC_MAX_SKEW_MS=30000
NONCE_TTL_SECONDS=30

# Batas ukuran request.
MAX_UPLOAD_BYTES=10485760
MAX_PROXY_BODY_BYTES=2097152

# URL publik frontend/gateway.
VITE_GATEWAY_URL=https://unified-inky-eight.vercel.app

# Kosongkan jika API dan frontend satu domain di Vercel.
# Isi kalau backend dipisah ke subdomain lain.
VITE_API_BASE_URL=

# Flag frontend.
VITE_ENABLE_REALTIME_ALERTS=true
VITE_ENABLE_DEV_LOGIN=true
