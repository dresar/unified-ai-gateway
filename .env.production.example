# Mode runtime aplikasi. Di production harus `production`.
NODE_ENV=production

# URL koneksi database PostgreSQL production.
# Dipakai backend untuk auth, credentials, logs, settings, dan data gateway lainnya.
DATABASE_URL=postgresql://user:password@host/database?sslmode=verify-full

# Secret untuk menandatangani dan memverifikasi JWT login dashboard.
# Gunakan string acak panjang, jangan pakai nilai pendek atau mudah ditebak.
JWT_SECRET=replace_with_a_long_random_secret

# URL Redis production (mis. Upstash/Redis Cloud).
# Dipakai untuk rate limit, cache, nonce/HMAC protection, quota counter, dan shared state antar instance Vercel.
REDIS_URL=rediss://default:password@your-redis-host:6379

# Daftar origin frontend yang diizinkan mengakses API.
# Pisahkan banyak domain dengan koma.
CORS_ORIGINS=https://your-project.vercel.app,https://your-domain.com

# Jumlah koneksi maksimum pool database per instance serverless.
# Untuk Vercel + Neon biasanya aman di 1-2 agar tidak cepat habis koneksinya saat scale.
DB_MAX_POOL=1

# Jika `true`, aplikasi akan gagal start di production bila REDIS_URL belum diisi.
# Disarankan tetap `true` agar behavior production konsisten.
REQUIRE_REDIS_IN_PRODUCTION=true

# Jika `true`, migrasi schema dijalankan saat runtime request.
# Untuk production sebaiknya `false`; migrasi dijalankan terpisah saat deploy/build.
ENABLE_RUNTIME_MIGRATIONS=false

# Mengaktifkan endpoint login development.
# Harus `false` di production.
ENABLE_DEV_LOGIN=false

# Mengaktifkan route internal/testing seperti helper test tertentu.
# Harus `false` di production.
ENABLE_INTERNAL_TEST_ROUTES=false

# Mengizinkan user mendaftar sendiri dari halaman login/register.
# Set `false` jika akun admin dibuat manual.
ENABLE_SELF_REGISTRATION=false

# Mengizinkan export credential sensitif dari dashboard.
# Sebaiknya `false` di production demi keamanan.
ALLOW_CREDENTIAL_EXPORT=false

# Membuka endpoint `/metrics`.
# Biasanya `false` di Vercel production kecuali memang diproteksi dan dibutuhkan.
EXPOSE_METRICS=false

# Membuka endpoint `/openapi.json`.
# Biasanya `false` di production agar surface publik lebih kecil.
EXPOSE_OPENAPI=false

# Durasi window rate limit dalam milidetik.
# Contoh 60000 = 1 menit.
RATE_LIMIT_WINDOW_MS=60000

# Batas request default per window untuk key/user yang memakai default global.
RATE_LIMIT_DEFAULT=1000

# Timeout circuit breaker saat menunggu upstream provider.
# Nilai lebih kecil menekan latency gagal, tapi terlalu kecil bisa terlalu agresif.
BREAKER_TIMEOUT_MS=500

# Jeda sebelum circuit breaker mencoba upstream lagi setelah status open.
BREAKER_HALF_OPEN_AFTER_MS=500

# Masa tenggang key lama setelah rotasi otomatis, dalam milidetik.
# Berguna agar request in-flight tidak langsung gagal saat key diganti.
API_KEY_GRACE_MS=60000

# Toleransi selisih waktu maksimum untuk validasi HMAC request, dalam milidetik.
HMAC_MAX_SKEW_MS=30000

# Lama penyimpanan nonce HMAC dalam detik untuk mencegah replay attack.
NONCE_TTL_SECONDS=30

# Batas maksimum ukuran upload file lewat gateway, dalam byte.
# Contoh ini = 10 MB.
MAX_UPLOAD_BYTES=10485760

# Batas maksimum ukuran body request proxy non-upload, dalam byte.
# Contoh ini = 2 MB.
MAX_PROXY_BODY_BYTES=2097152

# Base URL publik gateway/dashboard yang dipakai frontend untuk docs dan helper URL.
VITE_GATEWAY_URL=https://your-project.vercel.app

# Isi hanya jika API dipisah ke domain lain.
# Kosongkan jika frontend dan API sama-sama lewat rewrite same-origin di Vercel.
# VITE_API_BASE_URL=https://api.your-domain.com

# Mengaktifkan koneksi realtime alert via WebSocket di frontend.
# Untuk Vercel serverless sebaiknya `false`, karena polling lebih stabil.
VITE_ENABLE_REALTIME_ALERTS=false
