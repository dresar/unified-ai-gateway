{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/gateway/(.*)", "destination": "/api/index.js" },
    { "source": "/healthz", "destination": "/api/index.js" },
    { "source": "/((?!api/|gateway/|healthz|assets/|favicon\\.ico|placeholder\\.svg|robots\\.txt).*)", "destination": "/index.html" }
  ]
}
